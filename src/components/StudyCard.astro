---
import StudyItem from "./StudyItem.astro"


const STUDY = [
    {
        title: 'B.Sc. Systems Engineering',
		company: 'Universidad Distrital Francisco José de Caldas',
		init_date: 'August 2019',
		end_date: 'September 2025',
		description: 'Graduated with an Outstanding Student recognition from the academic work group. The program covered programming in multiple languages, system architectures, web development, databases, and project management. Completed multiple end-to-end projects bridging backend services, distributed systems, and open-source tooling.',
    },
    {
        title: 'Systems Technician',
		company: 'National Learning Service - SENA',
		init_date: 'February 2017',
		end_date: 'December 2018',
		description: 'Solid training in programming fundamentals and database administration using Access. Development of practical skills in technical problem solving, computer systems maintenance, and networks. During this training, I participated in various projects that allowed me to gain a deep understanding of technological infrastructure and its application in the business world.',
    }
]

---
<div class="flex gap-5 justify-center flex-col md:lg:flex-row">
    {
        STUDY.map(study => (
            <div class=" bg-secondDarkGray border border-firstRed rounded-lg shadow  max-w-xl">
            <StudyItem {...study} />
        </div>
    ))
    }
<div/>
