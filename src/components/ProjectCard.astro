---
const PROJECTS = [
    {
        title: 'GLUD Website, GNUBIES Course',
        description: 'Development and leadership in creating the website for the GLUD group (GNU/Linux Universidad Distrital), which serves as an educational platform for the GNUBIES course. In this project, my role was to direct the implementation using the FDD (Feature Driven Development) methodology, coordinating developers\' work and ensuring development quality. Additionally, I worked on creating the backend architecture with FastAPI and collaborated on frontend design using Astro, improving accessibility and user experience.',
        link: 'https://glud.org/',
        github: 'https://gitlab.com/GLUD/glud-page-2.0',
        image: 'glud.png',
        tags: ['Astro', 'FastApi']
    },
    {
        title: 'FourParks - Parking Management System',
        description: 'FourParks is a platform for parking space reservations. I primarily focused on backend development using Java and SpringBoot, creating a robust architecture to manage reservations, users, and database interactions. I also collaborated on frontend development, ensuring a smooth and efficient user experience. Additionally, I led the system deployment in a production environment, ensuring the application was accessible and stable for end users.',
        link: 'https://fourparks.site/',
        github: 'https://github.com/CristianGT089/four-parks',
        image: 'fourparks.png',
        tags: ['Java', 'SpringBoot', 'React']
    },
]

---

<div class="flex flex-col gap-6">
    {
        PROJECTS.map(({title, image, description, tags, link}) => (
            <a href={link} target="_blank" rel="noopener" class="group flex flex-col items-stretch overflow-hidden rounded-xl border border-firstRed/60 bg-secondDarkGray shadow-lg transition-all duration-300 hover:border-firstRed hover:shadow-firstRed/20 hover:shadow-2xl md:flex-row md:max-w-4xl">
                <div class="relative md:w-80 md:flex-shrink-0 overflow-hidden">
                    <img class="object-cover w-full h-64 md:h-full transition-transform duration-500 group-hover:scale-105" src={image} alt={title}>
                    <div class="absolute inset-0 bg-gradient-to-t from-secondDarkGray/80 via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:via-transparent md:to-secondDarkGray/40"></div>
                </div>
                <div class="flex flex-col justify-between p-6 leading-normal flex-1">
                    <div>
                        <h5 class="mb-2 text-2xl font-bold tracking-tight text-white">{title}</h5>
                        <p class="mb-4 font-normal text-white/80 text-pretty max-w-xl text-sm leading-relaxed">{description}</p>
                    </div>
                    <ul class="flex flex-wrap gap-2 text-xs">
                        {
                            tags.map(tag => (
                                <li class="rounded-full bg-firstDarkGray/60 px-2.5 py-1 text-gray-300 ring-1 ring-white/5">{tag}</li>
                            ))
                        }
                    </ul>
                </div>
            </a>
        ))
    }
</div>