---
const AWARDS = [
    {
        rank: '1st Bogotá · Top 3 Nationally',
        title: 'Hackathon Colombia 5.0',
        organizers: 'MinTIC · Corferias · APPS.CO',
        date: 'May 2026',
        description: "Awarded 1st place in Bogotá and Top 3 nationally at Colombia's largest government-backed hackathon. Built a working prototype in 48 hours alongside a team from Grupo GNU/Linux Universidad Distrital (GLUD), competing against teams from across the country.",
        tags: ['Teamwork', 'Rapid Prototyping', 'Open Source'],
        image: '/HackatonColombia50.webp',
    },
    {
        rank: 'Outstanding Student',
        title: 'Universidad Distrital Francisco José de Caldas',
        organizers: 'Work group recognition',
        date: '2024',
        description: 'Recognized as an outstanding student by the academic work group for contributions to collaborative projects and leadership within the university community.',
        tags: ['Leadership', 'Academic Excellence'],
        image: null,
    },
];
---

<div class="flex flex-col gap-6">
    {
        AWARDS.map(({ rank, title, organizers, date, description, tags, image }) => (
            <article
                class:list={[
                    'group relative overflow-hidden rounded-xl border border-firstRed/60 bg-secondDarkGray shadow-lg transition-all duration-300 hover:border-firstRed hover:shadow-firstRed/20 hover:shadow-2xl md:max-w-4xl',
                    image ? 'flex flex-col md:flex-row' : 'flex flex-col p-6',
                ]}
            >
                {image && (
                    <div class="relative md:w-80 md:flex-shrink-0 overflow-hidden">
                        <img
                            src={image}
                            alt={title}
                            class="h-64 w-full object-cover md:h-full transition-transform duration-500 group-hover:scale-105"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-secondDarkGray/80 via-transparent to-transparent md:bg-gradient-to-r md:from-transparent md:via-transparent md:to-secondDarkGray/40" />
                    </div>
                )}
                <div class:list={['flex flex-col gap-2', image ? 'p-6 md:flex-1' : '']}>
                    <span class="inline-flex w-fit items-center gap-1.5 rounded-full bg-firstRed/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-firstRed ring-1 ring-firstRed/40">
                        {rank}
                    </span>
                    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-1 mt-1">
                        <h5 class="text-xl font-bold tracking-tight text-white leading-tight">{title}</h5>
                        <time class="text-sm text-gray-400 whitespace-nowrap">{date}</time>
                    </div>
                    <p class="text-xs uppercase tracking-wide text-gray-500">{organizers}</p>
                    <p class="text-white/80 text-pretty mt-2 text-sm leading-relaxed">{description}</p>
                    <ul class="flex flex-wrap gap-2 mt-3 text-xs">
                        {tags.map((tag) => (
                            <li class="rounded-full bg-firstDarkGray/60 px-2.5 py-1 text-gray-300 ring-1 ring-white/5">
                                {tag}
                            </li>
                        ))}
                    </ul>
                </div>
            </article>
        ))
    }
</div>
